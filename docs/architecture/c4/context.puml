@startuml context
!includeurl https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml

title Coleta Premiada - C4 Nivel 1 - Contexto

LAYOUT_WITH_LEGEND()

Person(gestor, "Gestor", "Administra usuarios, programas, imoveis, consolidacoes, auditoria e relatorios.")
Person(supervisor, "Supervisor", "Acompanha operacao, consulta relatorios e ajusta constante de pontuacao.")
Person(coletor, "Coletor", "Registra coletas em campo e sincroniza pesagens/evidencias.")

System(cp, "Coleta Premiada", "Plataforma de incentivo a reciclagem: adesao de imoveis, coletas, pontos e desconto de IPTU.")

System_Ext(nominatim, "Nominatim", "Servico externo de geocodificacao usado pelo Core.")
System_Ext(llm, "LLM", "Servico de IA usado para gerar relatorios narrativos. Codigo atual: DeepSeek; opcional local via LM Studio.")
System(rabbitmq, "RabbitMQ", "Broker AMQP operado pelo sistema para eventos de imoveis/coletas e tarefas Celery do Core.")

Rel(gestor, cp, "Gerencia o programa e consulta relatorios", "HTTPS/JSON")
Rel(supervisor, cp, "Consulta dados operacionais e ajusta pontuacao", "HTTPS/JSON")
Rel(coletor, cp, "Autentica e registra coletas em campo", "HTTPS/JSON")

Rel(cp, nominatim, "Consulta coordenadas de imoveis", "HTTPS")
Rel(cp, llm, "Envia agregacoes para relatorio narrativo", "HTTPS/OpenAI-compatible")
Rel(cp, rabbitmq, "Publica e consome mensagens de dominio e tarefas assincronas", "AMQP")
Rel(rabbitmq, cp, "Entrega eventos entre Core, MS e workers", "AMQP")

' TODO: O requisito cita App React Native, mas o repositorio analisado em C:\Users\fdant\workspace\coleta-premiada-frontend e Next.js.
' Se existir um app mobile React Native em outro repositorio, incluir como cliente especifico do Coletor.

@enduml
