@startuml casos_de_uso
!theme plain
left to right direction
skinparam actorFontSize 14
skinparam usecaseFontSize 12
skinparam borderColor #999999
skinparam usecaseBorderColor #4a9e6b
skinparam actorBorderColor #2c3e50
skinparam arrowColor #555555

title Casos de Uso - Coleta Premiada

actor "Morador\n(Cidadão)" as morador
actor "Coletor\n(Agente de Campo)" as coletor
actor "Supervisor" as supervisor
actor "Gestor\n(Gerente Municipal)" as gestor
actor "Gerente Geral" as gerente_geral
actor "Sistemas\nExternos" as externo

rectangle "Autenticação" {
  usecase "UC01 - Cadastrar-se" as UC01
  usecase "UC02 - Fazer Login" as UC02
  usecase "UC03 - Login com Google" as UC03
  usecase "UC04 - Login com Matrícula" as UC04
  usecase "UC05 - Gerenciar Perfil" as UC05
}

rectangle "Imóveis" {
  usecase "UC06 - Cadastrar Imóvel" as UC06
  usecase "UC07 - Visualizar Imóvel" as UC07
  usecase "UC08 - Gerenciar Imóveis" as UC08
  usecase "UC09 - Buscar Imóvel" as UC09
  usecase "UC10 - Localizar Próximos" as UC10
}

rectangle "Coleta" {
  usecase "UC11 - Registrar Coleta" as UC11
  usecase "UC12 - Visualizar Histórico" as UC12
  usecase "UC13 - Sincronizar Coletas" as UC13
  usecase "UC14 - Operar Offline" as UC14
}

rectangle "Gestão do Programa" {
  usecase "UC15 - Gerenciar Programa" as UC15
  usecase "UC16 - Configurar Regras" as UC16
  usecase "UC17 - Gerenciar Ciclos" as UC17
  usecase "UC18 - Executar Consolidação" as UC18
