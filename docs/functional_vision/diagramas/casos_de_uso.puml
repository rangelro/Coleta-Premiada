}

rectangle "Pontuação e Benefícios" {
  usecase "UC20 - Visualizar Pontos" as UC20
  usecase "UC21 - Visualizar Descontos" as UC21
  usecase "UC22 - Configurar Pontuação" as UC22
}

rectangle "Contestações" {
  usecase "UC23 - Abrir Contestação" as UC23
  usecase "UC24 - Analisar Contestação" as UC24
}

rectangle "Relatórios" {
  usecase "UC25 - Dashboard Executivo" as UC25
