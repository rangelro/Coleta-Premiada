coletor --> UC09
coletor --> UC10
coletor --> UC11
coletor --> UC12
coletor --> UC13
coletor --> UC14

' Supervisor
supervisor --> UC08
supervisor --> UC12
supervisor --> UC22
supervisor --> UC26

' Gestor
gestor --> UC08
gestor --> UC12
gestor --> UC15
gestor --> UC16
gestor --> UC17
gestor --> UC18
gestor --> UC24
gestor --> UC25
gestor --> UC26
gestor --> UC27
gestor --> UC28
gestor --> UC29
gestor --> UC30

