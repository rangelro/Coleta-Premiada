# ══════════════════════════════════════════════════════════════════════════════
#  COLETA PREMIADA — variáveis de ambiente
#  Copie este arquivo para .env e preencha todos os valores antes de subir.
#  Nunca comite o .env com credenciais reais.
# ══════════════════════════════════════════════════════════════════════════════

# ─── PostgreSQL (core-db) ─────────────────────────────────────────────────────
POSTGRES_DB=coleta_premiada
POSTGRES_USER=postgres
POSTGRES_PASSWORD=troque_esta_senha

# ─── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=troque_esta_senha

# ─── MinIO (armazenamento de objetos) ─────────────────────────────────────────
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=troque_esta_senha
MINIO_ACCESS_KEY=minio_admin
MINIO_SECRET_KEY=troque_esta_senha
MINIO_BUCKET_NAME=coletas
MINIO_USE_HTTPS=False

# ─── MongoDB (ms-db) ──────────────────────────────────────────────────────────
MONGO_INITDB_DATABASE=coleta_db
MONGO_USER=coleta_user
MONGO_PASSWORD=troque_esta_senha

# ─── Django (Core e MS compartilham a mesma variável por padrão) ──────────────
# Para usar chaves distintas, exporte CORE_SECRET_KEY e MS_SECRET_KEY e ajuste
# os settings.py de cada serviço.
DJANGO_SECRET_KEY=troque_esta_chave_super_secreta_minimo_50_chars

# ─── Frontend (Next.js) ───────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8001
NEXT_PUBLIC_APP_NAME=Coleta Premiada

# ─── Grafana ──────────────────────────────────────────────────────────────────
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=troque_esta_senha

# ─── Google OAuth2 (console.cloud.google.com) ─────────────────────────────────
# Tipo: Web application
# URI de redirecionamento autorizado: ${NEXT_PUBLIC_API_URL}/auth/callback
GOOGLE_CLIENT_ID=seu_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=seu_client_secret

# ─── Nominatim (geocodificação) ───────────────────────────────────────────────
NOMINATIM_USER_AGENT="coleta-premiada/1.0 (youremail@example.com)"

# ─── Manutenção automatizada de bancos ────────────────────────────────────────
LOG_RETENTION_DAYS=90
LOG_CLEANUP_BATCH_SIZE=5000
MONGO_HOST=ms-db
MONGO_PORT=27017
MONGO_AUTH_DB=admin
MONGO_LOG_COLLECTION=audit_logs
MONGO_LOG_DATE_FIELD=created_at

# ─── Backup do PostgreSQL (serviço db-backup) ────────────────────────────────
# Agenda no formato cron (padrão: todo dia às 2h da manhã).
CRON_SCHEDULE="0 2 * * *"
# Quantidade de backups diários mantidos em /backups/postgres/daily.
BACKUP_KEEP_DAILY=7
# Quantidade de backups semanais mantidos em /backups/postgres/weekly.
BACKUP_KEEP_WEEKLY=4
# Dia da semana em que o backup diário também é copiado como semanal.
# Padrão ISO-8601: 1=segunda, 2=terça, 3=quarta, 4=quinta, 5=sexta, 6=sábado, 7=domingo.
BACKUP_WEEKLY_DAY=7
# Diretório de destino dos backups dentro do container.
BACKUP_DIR=/backups/postgres
# Upload offsite para MinIO (opcional — deixe vazio para desabilitar).
# O endpoint é o endereço do serviço MinIO dentro da rede Docker (ex.: minio:9000).
MINIO_ENDPOINT=
# Bucket de destino no MinIO para os backups.
MINIO_BACKUP_BUCKET=postgres-backups
# Webhook para notificações de sucesso/falha (opcional — Slack, Discord, ntfy.sh, etc.).
NOTIFY_WEBHOOK_URL=
