# ══════════════════════════════════════════════════════════════════════════════
#  COLETA PREMIADA — variáveis de ambiente
#  Copie este arquivo para .env e preencha todos os valores antes de subir.
#  Nunca comite o .env com credenciais reais.
# ══════════════════════════════════════════════════════════════════════════════

# ─── PostgreSQL (core-db) ─────────────────────────────────────────────────────
POSTGRES_DB=coleta_premiada
POSTGRES_USER=postgres
POSTGRES_PASSWORD=troque_esta_senha

# ─── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=troque_esta_senha

# ─── MinIO (armazenamento de objetos) ─────────────────────────────────────────
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=troque_esta_senha
MINIO_ACCESS_KEY=minio_admin
MINIO_SECRET_KEY=troque_esta_senha
MINIO_BUCKET_NAME=coletas
MINIO_USE_HTTPS=False

# ─── MongoDB (ms-db) ──────────────────────────────────────────────────────────
MONGO_INITDB_DATABASE=coleta_db
MONGO_USER=coleta_user
MONGO_PASSWORD=troque_esta_senha

# ─── Django (Core e MS compartilham a mesma variável por padrão) ──────────────
# Para usar chaves distintas, exporte CORE_SECRET_KEY e MS_SECRET_KEY e ajuste
# os settings.py de cada serviço.
DJANGO_SECRET_KEY=troque_esta_chave_super_secreta_minimo_50_chars

# ─── Frontend (Next.js) ───────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8001
NEXT_PUBLIC_APP_NAME=Coleta Premiada

# ─── Grafana ──────────────────────────────────────────────────────────────────
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=troque_esta_senha

# ─── Google OAuth2 (console.cloud.google.com) ─────────────────────────────────
# Tipo: Web application
# URI de redirecionamento autorizado: ${NEXT_PUBLIC_API_URL}/auth/callback
GOOGLE_CLIENT_ID=seu_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=seu_client_secret

# ─── Nominatim (geocodificação) ───────────────────────────────────────────────
NOMINATIM_USER_AGENT="coleta-premiada/1.0 (youremail@example.com)"
